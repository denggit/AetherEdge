# ============================================================
# AetherEdge V8 Live Runtime
# ============================================================

# Runtime mode. Use live_runtime for V8 live strategy orchestration.
AETHER_RUNTIME_MODE=live_runtime

# Market / symbol
AETHER_MARKET=ETH-USDT-PERP

# Strategy plugin
AETHER_STRATEGY=strategies.eth_lf_portfolio_v8:Strategy

# Exchanges
AETHER_EXCHANGES=okx,binance
AETHER_DATA_EXCHANGE=okx

# Master/follower execution roles are configuration, not code defaults.
# Current recommended live pairing: OKX data/master, Binance follower.
AETHER_MASTER_EXCHANGE=okx
AETHER_FOLLOWER_EXCHANGES=binance

# Master/follower policy
AETHER_ENTRY_DEVIATION_ALERT_PCT=0.005
AETHER_FOLLOWER_ENTRY_MAX_ATTEMPTS=3
AETHER_FOLLOWER_ENTRY_RETRY_DELAY_SECONDS=10
AETHER_MASTER_ENTRY_MAX_ATTEMPTS=3
AETHER_MASTER_ENTRY_RETRY_DELAY_SECONDS=10
AETHER_MASTER_FAIL_MANUAL_GRACE_SECONDS=1800
AETHER_CLOSE_ORPHAN_FOLLOWER_AFTER_GRACE=true
AETHER_DO_NOT_REJOIN_MID_POSITION_AFTER_FOLLOWER_DESYNC=true

# V8 does not need order book. Runtime requirements are also declared by the strategy plugin;
# this env value is retained for legacy fallback and should stay trades-only for V8.
AETHER_DATA_STREAMS=trades

# Local state / journal
AETHER_STATE_DB=data/state/aether_state.sqlite3
AETHER_ORDER_JOURNAL_DB=data/state/aether_order_journal.sqlite3
AETHER_SQLITE_BACKUP_DIR=data/state/backups

# Runtime scheduling / health
AETHER_WARMUP_ENABLED=true
AETHER_CLOSED_BAR_INTERVAL=4h
AETHER_CLOSED_BAR_BUFFER_MS=60000
AETHER_RANGE_PCT=0.002

# Current open 4H bucket trade/range-bar warmup.
# V8 uses this to rebuild current-bucket range bars after restart,
# and persisted trade coverage prevents repeated downloads.
AETHER_TRADE_WARMUP_BATCH_LIMIT=1000
OKX_HISTORY_TRADES_MAX_PAGES=200

AETHER_SCHEDULER_POLL_SECONDS=1.0
AETHER_PRODUCER_STALE_TIMEOUT_MS=60000

# Range speed history refresh
AETHER_RANGE_SPEED_REFRESH_ENABLED=true
AETHER_RANGE_SPEED_REFRESH_SECONDS=60
AETHER_RANGE_SPEED_STATUS_WARNING_SECONDS=600

# Range speed historical backfill
AETHER_RANGE_BACKFILL_ENABLED=true
AETHER_RANGE_BACKFILL_REQUIRED_BUCKETS=100
AETHER_RANGE_BACKFILL_LOOKBACK_BUCKETS=160
AETHER_RANGE_BACKFILL_MAX_BUCKETS_PER_CYCLE=6
AETHER_RANGE_BACKFILL_MAX_DAYS_PER_CYCLE=1
AETHER_RANGE_BACKFILL_SLEEP_SECONDS=30
AETHER_RANGE_BACKFILL_HEARTBEAT_STALE_SECONDS=180
AETHER_RANGE_BACKFILL_RESTART_COOLDOWN_SECONDS=300
AETHER_RANGE_BACKFILL_MONITOR_SECONDS=60
AETHER_RANGE_BACKFILL_STATUS_PATH=data/state/range_backfill_status.json
AETHER_RANGE_BACKFILL_LOCK_PATH=data/state/range_backfill.lock
AETHER_RANGE_BACKFILL_LOW_PRIORITY=true
AETHER_RANGE_BACKFILL_CHUNKSIZE=50000
AETHER_RANGE_BACKFILL_RAW_ROOT=data/okx/raw/trades
AETHER_RANGE_BACKFILL_SAVE_RAW_TRADES=false
AETHER_RANGE_BACKFILL_CHUNK_SLEEP_SECONDS=0.1
AETHER_RANGE_BACKFILL_MAX_SECONDS_PER_CYCLE=30
AETHER_RANGE_BACKFILL_MAX_TRADES_PER_CYCLE=300000
AETHER_MARKET_DATA_DB=data/market_data/aether_market_data.sqlite3

# ============================================================
# Safety switches
# ============================================================

# Safe default: no real orders. For direct live trading set:
# AETHER_DRY_RUN=false
# AETHER_LIVE_TRADING=true
AETHER_DRY_RUN=true
AETHER_LIVE_TRADING=false

# ============================================================
# Alerts
# ============================================================

AETHER_ENABLE_EMAIL_ALERT=true
EMAIL_SENDER=你的QQ邮箱@qq.com
EMAIL_PASSWORD=你的QQ邮箱授权码
EMAIL_RECEIVER=接收提醒的邮箱@qq.com

# ============================================================
# OKX
# ============================================================

OKX_API_KEY=你的_okx_api_key
OKX_SECRET_KEY=你的_okx_secret_key
OKX_PASSPHRASE=你的_okx_passphrase

# true = OKX simulation, false = OKX real market
OKX_SANDBOX=true
OKX_LEVERAGE=15

# ============================================================
# Binance USD-M Futures
# ============================================================

BINANCE_API_KEY=你的_binance_api_key
BINANCE_SECRET_KEY=你的_binance_secret_key

# true = Binance Futures testnet, false = Binance real market
BINANCE_SANDBOX=true
BINANCE_LEVERAGE=15

# ============================================================
# Execution defaults
# ============================================================

API_TIMEOUT_SECONDS=10
BINANCE_RECV_WINDOW_MS=5000
MARGIN_MODE=isolated
