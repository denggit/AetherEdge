# ===== OKX =====
OKX_API_KEY=你的_okx_api_key
OKX_SECRET_KEY=你的_okx_secret_key
OKX_PASSPHRASE=你的_okx_passphrase

# 是否用 OKX 模拟盘
# true = 模拟盘，会带 x-simulated-trading: 1
# false = 真实盘
OKX_SANDBOX=true
# =================================

# ===== Binance USD-M Futures =====
BINANCE_API_KEY=你的_binance_api_key
BINANCE_SECRET_KEY=你的_binance_secret_key

# 是否用 Binance 测试网
# true = testnet
# false = 真实盘
BINANCE_SANDBOX=true
# =================================